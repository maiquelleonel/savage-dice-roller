{
  "manifest_version": 3,
  "name": "Savage Worlds Dice Roller for Google Meet",
  "version": "1.0",
  "description": "A dice roller for Savage Worlds RPG integrated into Google Meet.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://meet.google.com/*"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"]
    }
  ]
}
